# Normalize line endings: let Git handle EOL so the repo stays consistent
# across Windows/macOS/Linux and CI.
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries — never touch
*.png   binary
*.jpg   binary
*.svg   binary
*.ico   binary
*.pfx   binary
